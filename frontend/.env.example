# Frontend environment variables.
# Copy to `.env.local` (dev) or `.env.production` (build) and edit.
#
# VITE_API_BASE_URL controls where the SPA sends API calls.
#
# Recommended (single-origin behind the reverse proxy in deploy/):
#   - Leave VITE_API_BASE_URL UNSET. The frontend defaults to the relative
#     path "/api" and inherits whatever scheme the page is loaded with
#     (http://localhost in plain dev, https://your-domain.com in prod).
#
# Only set VITE_API_BASE_URL when the API is on a different origin from the
# SPA. In that case, ALWAYS use https:// in any HTTPS deployment, otherwise
# browsers will block requests as mixed content.
#
# Examples:
#   # Same-origin (default, recommended): leave commented out
#   # VITE_API_BASE_URL=
#
#   # API hosted on a separate subdomain over HTTPS:
#   # VITE_API_BASE_URL=https://api.your-domain.com
#
#   # Local backend without the reverse proxy (legacy dev setup):
#   # VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional: link to the API docs from the in-app integration helper.
# VITE_DOCS_URL=https://your-domain.com/docs

# Optional: HTTPS dev certs (mkcert). Paths are server-side only (not VITE_*).
# After `mkcert -install` and `mkcert localhost 127.0.0.1`, either:
#   A) Copy your existing key/cert to frontend/dev-certs/ssl-key.pem and
#      frontend/dev-certs/ssl-cert.pem (any names mkcert gave you → rename),
#   B) Or point to the files mkcert created (absolute paths, or paths relative
#      to the frontend/ folder):
# DEV_SSL_KEY_FILE=C:\path\to\localhost+1-key.pem
# DEV_SSL_CERT_FILE=C:\path\to\localhost+1.pem
# If neither A nor B is set, Vite uses @vitejs/plugin-basic-ssl (Chrome warns).
