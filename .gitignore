# Python cache
__pycache__/
*.pyc

# Virtual environments
venv/
.venv/

# Environment variables
*.env
.env.*
.env
backend/.env

# Node / Vite
node_modules/
.vite/
# ...but commit example files so the expected variables are documented.
!.env.example
!*/.env.example

# Logs
*.log

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Uploads
uploads/
backend/uploads/

# Local TLS certificates generated by mkcert (never commit private keys).
deploy/certs/

# Dev-only self-signed certs (backend/scripts/generate_dev_tls.py).
backend/dev-certs/

# mkcert or other PEMs for Vite HTTPS (see frontend/.env.example).
frontend/dev-certs/*.pem
