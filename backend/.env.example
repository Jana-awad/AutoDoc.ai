# Copy to backend/.env and fill in real values. Never commit your real .env.

# --- PostgreSQL ---
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/autodoc_db

# --- Auth (JWT signing) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

# --- Background workers (optional, only if you run Celery) ---
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --- Google Cloud Vision OCR ---
# Path to a service-account JSON file with the Vision API enabled.
# GOOGLE_APPLICATION_CREDENTIALS=C:\\path\\to\\google-vision-key.json
# GOOGLE_VISION_QUOTA_PROJECT_ID=your-gcp-project-id

# --- LLM (OpenAI) ---
# These are the GLOBAL fallbacks. Each template can override the model /
# temperature / max_tokens from the Template Builder UI.
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4o-mini

# --- OCR tuning ---
PDF_OCR_DPI=300
PDF_EMBEDDED_MIN_CHARS_TO_SKIP_OCR=40
